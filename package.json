{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"next dev -H 0.0.0.0\" \"tsx watch src/server.ts\"",
    "dev:web": "next dev",
    "api:dev": "tsx watch src/server.ts",
    "api:start": "tsx src/server.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/run-migrations.ts",
    "db:seed": "tsx scripts/seed-db.ts",
    "db:check": "tsx scripts/check-consistency.ts",
    "api:test:critical": "tsx scripts/api-critical-tests.ts",
    "inngest:dev": "npx inngest-cli@latest dev -u http://localhost:4000/api/inngest"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@perawallet/connect": "^1.5.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "algosdk": "^3.5.1",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.21.2",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "inngest": "^3.35.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "nodemailer": "^6.10.0",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^10.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
